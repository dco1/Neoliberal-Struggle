# Alpaca Paper Trading
ALPACA_API_KEY=your_paper_api_key_here
ALPACA_SECRET_KEY=your_paper_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Agent Settings
PORT=3000
AGENT_INTERVAL_MINUTES=15        # How often the agent loop runs
MARKET_OPEN_HOUR=9               # ET
MARKET_OPEN_MINUTE=30
MARKET_CLOSE_HOUR=16
MARKET_CLOSE_MINUTE=0

# Capital Allocation (paper money)
BOOK_A_CAPITAL=50000
BOOK_B_CAPITAL=50000

# Strategy Weights (must sum to 1.0)
WOKE_WEIGHT=0.4
FINANCIAL_WEIGHT=0.6

# Guardrails
MAX_POSITION_PCT=0.10            # Max 10% of book capital in one stock
MAX_TRADE_SIZE=5000              # Max single trade in dollars
DAILY_LOSS_LIMIT_PCT=0.05        # Pause book if down 5% in a day
TRADE_COOLDOWN_MINUTES=60        # Min time between trades on same ticker
WOKE_FLOOR=30                    # Never hold a stock scoring below this
